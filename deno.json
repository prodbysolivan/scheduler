{
  "name": "@prodby/solivan",
  "description": "High-performance loop lifecycle manager with priority-based task orchestration.",
  "version": "1.0.0",
  "exports": "./source/index.ts",
  "publish": {
    "include": ["source/**/*.ts", "deno.json", "README.md", "LICENSE"]
  },
  "lint": {
    "rules": {
      "exclude": ["adjacent-overload-signatures"]
    }
  },
  "compilerOptions": {
    "lib": ["deno.window", "dom"]
  },
  "tasks": {
    "format": "deno fmt",
    "lint": "deno lint",
    "clean": "rm -rf build"
  },
  "imports": {
    "@prodbysolivan/signal": "jsr:@prodbysolivan/signal@^1.1.2",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/mock": "https://deno.land/std@0.224.0/testing/mock.ts"
  }
}
